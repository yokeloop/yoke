{
  "name": "yoke",
  "version": "1.0.0",
  "private": true,
  "description": "Marketplace of skills and commands for Claude Code",
  "author": {
    "name": "Heliotic"
  },
  "license": "MIT",
  "keywords": [
    "marketplace",
    "skills",
    "commands",
    "workflow",
    "productivity"
  ],
  "repository": "https://github.com/yokeloop/yoke",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write \"**/*.{md,json}\" 2>&1 | tail -5",
    "format:check": "prettier --check \"**/*.{md,json}\" 2>&1 | tail -5"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3"
  },
  "lint-staged": {
    "*.{md,json}": "prettier --write"
  }
}
